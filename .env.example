# === LLM ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === LangSmith tracing (required) ===
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=sre-bot
LANGSMITH_TRACING=true

# === Slack ===
# Bot token (xoxb-...) — needs chat:write, chat:write.public scopes
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App-level token (xapp-...) — for Socket Mode (connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here
# Channel to post alerts and health reports
SLACK_CHANNEL=#sre-alerts

# === Monitoring schedule ===
# How often the bot autonomously checks the cluster (minutes)
MONITOR_INTERVAL_MINUTES=30

# === Kubernetes ===
# Leave empty to auto-discover all non-system namespaces
DEFAULT_NAMESPACES=

# === Optional ===
# Prometheus URL for richer metrics (leave empty to rely on metrics-server)
PROMETHEUS_URL=
API_PORT=8080
